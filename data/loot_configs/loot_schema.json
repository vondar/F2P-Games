{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loot Config Schema",
  "description": "Schema for F2P loot system probability and pity configurations.",
  "type": "object",
  "properties": {
    "system_name": {
      "type": "string"
    },
    "base_prob": {
      "type": "number",
      "minimum": 0,
      "maximum": 1.0
    },
    "pity_config": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["linear", "exponential"]
        },
        "start": {
          "type": "integer",
          "minimum": 1
        },
        "end": {
          "type": "integer",
          "minimum": 1
        },
        "target_prob": {
          "type": "number",
          "minimum": 0,
          "maximum": 1.0
        }
      },
      "required": ["type", "start"]
    },
    "cost_per_pull_usd": {
      "type": "number",
      "minimum": 0
    },
    "acquisition_threshold": {
      "type": "integer",
      "minimum": 1
    }
  },
  "required": ["system_name", "base_prob", "cost_per_pull_usd"]
}
